{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-and-shell",
  "description": "Local Bandoo management UI and WebApp shell chrome permissions.",
  "windows": ["main", "webapp-*"],
  "webviews": ["main", "webapp-*-shell"],
  "permissions": [
    "allow-runtime-info",
    "allow-list-webapps",
    "allow-upsert-webapp",
    "allow-delete-webapp",
    "allow-install-desktop-entry",
    "allow-remove-desktop-entry",
    "allow-desktop-integration-statuses",
    "allow-launch-webapp",
    "allow-start-selector-capture",
    "allow-start-action-recording",
    "allow-list-automations",
    "allow-upsert-automation",
    "allow-delete-automation",
    "allow-execute-automation",
    "allow-list-user-scripts",
    "allow-upsert-user-script",
    "allow-delete-user-script",
    "allow-execute-user-script",
    "allow-list-prompt-templates",
    "allow-upsert-prompt-template",
    "allow-delete-prompt-template",
    "allow-list-theme-presets",
    "allow-upsert-theme-preset",
    "allow-delete-theme-preset",
    "allow-app-settings",
    "allow-save-app-settings",
    "allow-list-run-logs",
    "allow-bridge-request",
    "core:default",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-start-dragging",
    "opener:default"
  ]
}
